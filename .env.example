# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# PayPal
# Found at: developer.paypal.com → Apps & Credentials → Your App → Client ID
VITE_PAYPAL_CLIENT_ID=

# EmailJS
# Found at: dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Google Apps Script
# Your deployed web app URL (see README for how to get this)
VITE_APPS_SCRIPT_URL=

# Manager login password (choose anything you like)
VITE_MANAGER_PASSWORD=
