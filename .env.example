# ─── Developer credentials — set ONCE by the developer, never by the owner ───
# Store these in Netlify → Site configuration → Environment variables.
# NEVER commit this file with real values.

# ── Google OAuth (Google Cloud Console) ──────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Application type: Web application
# Authorised redirect URIs:
#   https://YOUR-SITE.netlify.app/.netlify/functions/auth-google-callback
#   http://localhost:8888/.netlify/functions/auth-google-callback  ← local dev
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── PayPal REST (developer.paypal.com) ───────────────────────────────────────
# Create at: developer.paypal.com → Apps & Credentials → Create App
# Under "App Settings" enable "Log In with PayPal" and add redirect URI:
#   https://YOUR-SITE.netlify.app/.netlify/functions/auth-paypal-callback
#   http://localhost:8888/.netlify/functions/auth-paypal-callback   ← local dev
# PAYPAL_ENV: 'sandbox' for testing, 'live' for production
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# ── EmailJS (dashboard.emailjs.com) ──────────────────────────────────────────
# Order confirmation emails are sent server-side. Owner never sees these keys.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# ── Session signing ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Netlify site URL (set automatically by Netlify in production) ─────────────
# Only needed for local dev — set to http://localhost:8888
# URL=http://localhost:8888
